# LogicaKids Pro - Frontend Environment Variables Example

# ==========================================
# SRE (Site Reliability Engineering) Metrics
# ==========================================
# Endpoint to fetch progress data for the SRE dashboard.
# Local development fallback: http://localhost:9323/progreso_sre.json
VITE_SRE_ENDPOINT=http://localhost:9323/progreso_sre.json

# ==========================================
# Backend API Integration
# ==========================================
# Base URL for the backend authentication and pedagogy APIs
VITE_API_BASE_URL=http://localhost:8000/api
